generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ───────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  plan           Plan      @default(FREE)
  stripeCustomerId   String?   @unique
  stripeSubscriptionId String?
  stripePriceId      String?
  stripeCurrentPeriodEnd DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  vaultItems    VaultItem[]
  beneficiaries Beneficiary[]
  deadManSwitch DeadManSwitch?
  activityLogs  ActivityLog[]
  files         File[]
  payments      CryptoPayment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  expires   DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Vault ──────────────────────────────────────────────

model VaultItem {
  id            String       @id @default(cuid())
  userId        String
  type          VaultType
  title         String
  encryptedData String       @db.Text   // AES-256-GCM encrypted blob
  iv            String                   // Initialization vector
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments   BeneficiaryItem[]

  @@index([userId])
}

// ─── Beneficiaries ──────────────────────────────────────

model Beneficiary {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String
  phone     String?
  relation  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items BeneficiaryItem[]

  @@index([userId])
}

model BeneficiaryItem {
  id            String      @id @default(cuid())
  beneficiaryId String
  vaultItemId   String
  note          String?     @db.Text

  beneficiary Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  vaultItem   VaultItem   @relation(fields: [vaultItemId], references: [id], onDelete: Cascade)

  @@unique([beneficiaryId, vaultItemId])
}

// ─── Dead Man's Switch ──────────────────────────────────

model DeadManSwitch {
  id             String        @id @default(cuid())
  userId         String        @unique
  intervalDays   Int           @default(30)
  status         SwitchStatus  @default(ACTIVE)
  lastCheckIn    DateTime      @default(now())
  nextCheckDate  DateTime
  gracePeriodDays Int          @default(3)
  triggered      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pings SwitchPing[]
}

model SwitchPing {
  id          String     @id @default(cuid())
  switchId    String
  sentAt      DateTime   @default(now())
  respondedAt DateTime?
  channel     String     @default("email")

  deadManSwitch DeadManSwitch @relation(fields: [switchId], references: [id], onDelete: Cascade)

  @@index([switchId])
}

// ─── Activity Log ───────────────────────────────────────

model File {
  id           String   @id @default(cuid())
  userId       String
  name         String
  originalName String
  mimeType     String
  size         Int
  storagePath  String
  iv           String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?  @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Crypto Payments ────────────────────────────────────

model CryptoPayment {
  id            String        @id @default(cuid())
  userId        String
  plan          Plan
  amountUsdt    Decimal       @db.Decimal(18, 6)
  network       String        @default("TRC20") // TRC20, ERC20, BEP20
  walletAddress String        // Our receiving wallet
  txHash        String?       @unique // User-submitted TX hash
  status        PaymentStatus @default(PENDING)
  expiresAt     DateTime      // Payment window (30 min)
  confirmedAt   DateTime?
  periodDays    Int           @default(30)
  billing       String        @default("monthly") // monthly, yearly
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([txHash])
  @@index([createdAt])
}

// ─── Enums ──────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  PRO_PLUS
}

enum VaultType {
  PASSWORD
  DOCUMENT
  MESSAGE
  INSTRUCTION
}

enum SwitchStatus {
  ACTIVE
  PAUSED
  TRIGGERED
  DISABLED
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  CONFIRMING
  CONFIRMED
  EXPIRED
  FAILED
}
